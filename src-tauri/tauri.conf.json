{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SoupaWhisper",
  "version": "0.1.0",
  "identifier": "com.soupawhisper.voice",
  "build": {
    "beforeBuildCommand": "bun run build",
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SoupaWhisper",
        "width": 900,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/silero_vad_v4.onnx", "themes"],
    "macOS": {
      "signingIdentity": "TALRI Dev"
    }
  },
  "plugins": {}
}
