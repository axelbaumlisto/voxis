{
  "manifest_version": 2,
  "id": "lavalamp",
  "name": "Lava Lamp",
  "description": "Raymarched wax blobs circulating around the overlay like a lava lamp — rise, drift, sink, repeat (WebGL).",
  "api_version": 1,
  "overlay_width": 120,
  "overlay_height": 120,
  "entry": "theme.js",
  "params": {
    "shine": 28,
    "specWeight": 0.6,
    "saturation": 1.7,
    "speed": 0.55,
    "zoom": 1.7,
    "colors": ["#ff3b1f", "#ff7a00", "#ffb300", "#ff2d6f"]
  }
}
